# backend/.env.example
# Copy to .env and change the secrets before deploying.

# ── Two separate JWT signing secrets ────────────────────────────────────────
# IMPORTANT: These MUST be different strings.
# If a leaked access token secret could forge refresh tokens, the whole
# rotation scheme is broken.
ACCESS_TOKEN_SECRET=access-secret-change-me-in-prod-use-64-random-chars
REFRESH_TOKEN_SECRET=refresh-secret-change-me-in-prod-use-64-random-chars

# ── Token lifetimes ──────────────────────────────────────────────────────────
ACCESS_TOKEN_TTL_SECONDS=300          # 5 minutes
REFRESH_TOKEN_TTL_SECONDS=604800      # 7 days

# ── Blacklist ────────────────────────────────────────────────────────────────
BLACKLIST_SWEEP_INTERVAL_SECONDS=60   # how often the sweep thread runs

# ── Cookie ───────────────────────────────────────────────────────────────────
COOKIE_SECURE=false         # set to true when running over HTTPS
COOKIE_SAMESITE=lax         # lax | strict | none
# COOKIE_DOMAIN=            # leave blank = current domain

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8000
CORS_ORIGIN=http://localhost:5173